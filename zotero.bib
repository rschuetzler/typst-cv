@article{giboney2023Know,
	title = {Know your enemy: Conversational agents for security, education, training, and awareness at scale},
	volume = {129},
	rights = {All rights reserved},
	issn = {0167-4048},
	url = {https://www.sciencedirect.com/science/article/pii/S0167404823001177},
	doi = {10.1016/j.cose.2023.103207},
	shorttitle = {Know your enemy},
	abstract = {Social engineering attacks are widespread, costly, and challenging to mitigate through technical means. Companies allocate considerable resources toward security education, training, and awareness. However, the cost of these efforts is high, and the efficacy is questionable, particularly for defending against social engineering attacks. To improve security training for employees against social engineering at scale, we have designed a conversational agent to simulate a person becoming the victim of a social engineering attack. We build on Utility theory and previous social engineering, adversarial thinking, and conversational agent research. We designed a conversational agent to allow humans to learn and practice social engineering techniques in a fun and engaging setting. Users learn how an attacker might use these techniques by performing them. We present the design of a conversational agent for social engineering training and demonstrate a process to measure adversarial thinking in a computer-mediated conversational context. We showed that the conversational agent performs well and accurately measures adversarial thinking through two studies.},
	pages = {103207},
	journaltitle = {Computers \& Security},
	shortjournal = {Computers \& Security},
	author = {Giboney, Justin Scott and Schuetzler, Ryan M and Grimes, G. Mark},
	urldate = {2023-04-06},
	date = {2023-06-01},
	langid = {english},
	keywords = {Adversarial thinking, Conversational agents, Social engineering},
}

