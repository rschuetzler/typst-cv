@article{schuetzlerImpactChatbotConversational2020,
	title = {The impact of chatbot conversational skill on engagement and perceived humanness},
	volume = {37},
	rights = {All rights reserved},
	issn = {0742-1222},
	url = {https://doi.org/10.1080/07421222.2020.1790204},
	doi = {10.1080/07421222.2020.1790204},
	abstract = {Conversational agents ({CAs})—frequently operationalized as chatbots—are computer systems that leverage natural language processing to engage in conversations with human users. {CAs} are often operationalized as chatbots which are used for many applications including technical support, customer service, and digital personal assistants. Despite their widespread use, little research to date has investigated how improving the conversational skill of a {CA} impacts user perceptions of the agent. To elucidate this relationship, this research uses Social Presence Theory to describe how conversational skill influences perceived social presence and ultimately anthropomorphism of a chatbot. We conducted a series of studies in which 450 participants interacted with {CAs} exhibiting varying levels of conversational skill. We show that people perceive a more skilled {CA} to be more socially present and anthropomorphic than a less skilled {CA}. This research advances the knowledge of computer-human interface in information systems, as {CA} research to date has largely focused on the technical challenges rather than the behavioral questions of how users interact with {CAs}.},
	pages = {875--900},
	number = {3},
	journaltitle = {Journal of Management Information Systems},
	publisher = {Routledge},
	author = {Schuetzler, Ryan M and Grimes, G. Mark and Giboney, Justin Scott},
	urldate = {2020-12-11},
	date = {2020-07-02},
	keywords = {Conversational agents, anthropomorphism, chatbots, social presence, system humanness, user engagement},
}

