@article{barlowOverviewGuidanceAgile2011,
  title = {Overview and Guidance on Agile Development in Large Organizations},
  author = {Barlow, Jordan B and Giboney, Justin Scott and Keith, Mark Jeffrey and Wilson, David W and Schuetzler, Ryan and Lowry, Paul Benjamin and Vance, Anthony},
  date = {2011},
  journaltitle = {Communications of the Association for Information Systems},
