  shorttitle = {When Programs Collide},
  author = {Young, Jacob A. and Biros, David P. and Schuetzler, Ryan M. and Smith, Tyler J. and Stephens, Paul R. and Syler, Rhonda A. and Zheng, Shawn H.},
